{
  "schemaVersion": 1,
  "id": "tabnamedimmer",
  "version": "${version}",
  "name": "Tab Name Dimmer",
  "description": "Dims non-whitelisted player names in the tab list while Shift is held.",
  "icon": "assets/tabnamedimmer/icon.png",
  "authors": [
    "LTS_Server"
  ],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "org.lts.tabnamedimmer.TabNameDimmerClient"
    ],
    "modmenu": [
      "org.lts.tabnamedimmer.compat.TabNameDimmerModMenu"
    ]
  },
  "mixins": [
    {
      "config": "tabnamedimmer.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": ">=26.1.2 <=26.2",
    "java": ">=25"
  },
  "suggests": {
    "modmenu": "*"
  }
}
